# Copy to .env.deploy and fill in (file is gitignored):
#   cp deploy.env.example .env.deploy
#
# If login still fails, ask the host: correct FTP host, username format,
# current password, and whether they require FTPS (then set FTP_USE_SSL=1).

FTP_HOST=ftp.medicalcontractor.ca
FTP_USER=fieldwire@medicalcontractor.ca
FTP_PASSWORD=

